{
	"name": "@easystock/app",
	"version": "1.0.0",
	"main": "expo-router/entry",
	"scripts": {
		"start": "expo start",
		"start:e2e": "node scripts/tooling.mjs e2e:expo start --dev-client --clear --localhost --port 8088 --ios",
		"android": "expo run:android",
		"ios": "expo run:ios",
		"ios:e2e": "node scripts/tooling.mjs e2e:expo run:ios",
		"web": "expo start --web",
		"test": "jest",
		"test:coverage": "jest --coverage",
		"test:seed:reset": "node scripts/tooling.mjs seed:reset",
		"test:seed:verify": "node scripts/tooling.mjs seed:verify",
		"test:integration": "npm run test:seed:verify && jest --config jest.integration.config.js --runInBand",
		"test:design-system:ios": "node scripts/tooling.mjs proof:design-system --platform ios",
		"test:design-system:ios:update": "node scripts/tooling.mjs proof:design-system --platform ios --update-baseline",
		"test:design-system:android": "node scripts/tooling.mjs proof:design-system --platform android --skip-visual-regression",
		"test:e2e": "npm run test:e2e:full",
		"test:e2e:critical": "npm run test:seed:reset && npm run test:seed:verify && node scripts/tooling.mjs e2e:maestro test .maestro/critical/",
		"test:e2e:full": "npm run test:seed:reset && npm run test:seed:verify && node scripts/tooling.mjs e2e:maestro test .maestro/*.yaml --exclude .maestro/auth_invalid_login.yaml --exclude .maestro/_scratch_auth_probe.yaml",
		"test:e2e:negative-auth": "npm run test:seed:reset && npm run test:seed:verify && node scripts/tooling.mjs e2e:maestro test .maestro/auth_invalid_login.yaml",
		"test:e2e:report": "npm run test:seed:reset && npm run test:seed:verify && node scripts/tooling.mjs e2e:maestro test .maestro/*.yaml --exclude .maestro/auth_invalid_login.yaml --exclude .maestro/_scratch_auth_probe.yaml --format junit --output report.xml",
		"test:pr": "npm run typecheck && npm run lint && npm run test:coverage && npm run test:seed:reset && npm run test:integration && npm run test:e2e:critical",
		"audit:security": "npm audit --audit-level=high",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"lint:magic-numbers": "eslint . 2>&1 | grep -c '@typescript-eslint/no-magic-numbers' || true",
		"lint:style": "stylelint \"**/*.{css,scss}\" --allow-empty-input",
		"i18n:extract": "i18next-parser",
		"format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
		"typecheck": "tsc --noEmit",
		"check:hex": "node scripts/tooling.mjs check:hex",
		"check:ui-tokens": "node scripts/tooling.mjs check:ui-tokens",
		"check:design-system": "node scripts/tooling.mjs check:design-system",
		"check:ui-shell": "node scripts/tooling.mjs check:ui-shell",
		"check:workspace-packages": "node scripts/tooling.mjs check:workspace-packages",
		"check:inventory-consumer": "node scripts/tooling.mjs check:inventory-consumer",
		"check:release-discipline": "node scripts/tooling.mjs check:release-discipline",
		"check:extraction-readiness": "node scripts/tooling.mjs check:extraction-readiness",
		"check:routes": "node scripts/tooling.mjs check:routes",
		"check:runtime-boundaries": "node scripts/tooling.mjs check:runtime-boundaries",
		"check:product-surfaces": "node scripts/tooling.mjs check:product-surfaces",
		"check:migrations": "node scripts/tooling.mjs check:migrations",
		"check:db-types": "node scripts/tooling.mjs check:db-types",
		"check:i18n": "node scripts/check-i18n-keys.mjs && node scripts/check-i18n-hardcoded.mjs",
		"commitlint": "node scripts/check-commit-message.mjs",
		"release:notes": "node scripts/generate-release-notes.mjs",
		"db:types:generate": "npx supabase gen types typescript --local > src/types/database.ts",
		"generate:tokens": "node scripts/tooling.mjs generate:tokens",
		"generate:ui-library": "node scripts/tooling.mjs generate:ui-library",
		"generate:design-system": "npm run generate:tokens && npm run generate:ui-library && node scripts/tooling.mjs generate:component-catalog",
		"validate": "npm run format && npm run typecheck && npm run check:hex && npm run check:routes && npm run check:runtime-boundaries && npm run check:i18n && npm run check:ui-tokens && npm run check:design-system && npm run check:ui-shell && npm run check:workspace-packages && npm run check:inventory-consumer && npm run check:release-discipline && npm run check:extraction-readiness && npm run lint && npm run test && npm run test:integration",
		"prepare": "husky"
	},
	"dependencies": {
		"@easydesign/design-system": "file:src/design-system",
		"@easydesign/ui-shell": "file:src/ui-shell",
		"@formatjs/intl-datetimeformat": "^7.3.2",
		"@formatjs/intl-getcanonicallocales": "^3.2.3",
		"@formatjs/intl-listformat": "^8.3.2",
		"@formatjs/intl-locale": "^5.3.2",
		"@formatjs/intl-numberformat": "^9.3.2",
		"@formatjs/intl-pluralrules": "^6.3.2",
		"@formatjs/intl-relativetimeformat": "^12.3.2",
		"@hookform/resolvers": "^5.2.2",
		"@react-native-async-storage/async-storage": "2.2.0",
		"@react-native-community/datetimepicker": "^8.4.4",
		"@shopify/flash-list": "^2.0.2",
		"@supabase/supabase-js": "^2.99.3",
		"date-fns": "^4.1.0",
		"expo": "^54.0.0",
		"expo-camera": "~17.0.10",
		"expo-clipboard": "~8.0.8",
		"expo-constants": "~18.0.13",
		"expo-dev-client": "~6.0.20",
		"expo-document-picker": "~14.0.8",
		"expo-file-system": "~19.0.21",
		"expo-haptics": "~15.0.8",
		"expo-image": "~3.0.11",
		"expo-image-manipulator": "~14.0.8",
		"expo-image-picker": "~17.0.10",
		"expo-linking": "~8.0.11",
		"expo-local-authentication": "~17.0.8",
		"expo-localization": "~17.0.8",
		"expo-print": "~15.0.8",
		"expo-router": "~6.0.23",
		"expo-secure-store": "~15.0.8",
		"expo-sharing": "~14.0.8",
		"expo-status-bar": "~3.0.9",
		"i18next": "^25.10.4",
		"immer": "^11.1.4",
		"intl-pluralrules": "^2.0.1",
		"lucide-react-native": "^0.577.0",
		"react": "19.1.0",
		"react-hook-form": "^7.72.0",
		"react-i18next": "^16.6.1",
		"react-native": "0.81.5",
		"react-native-chart-kit": "^6.12.0",
		"react-native-gesture-handler": "~2.28.0",
		"react-native-keyboard-controller": "1.18.5",
		"react-native-qrcode-svg": "^6.3.21",
		"react-native-reanimated": "~4.1.1",
		"react-native-safe-area-context": "~5.6.0",
		"react-native-screens": "~4.16.0",
		"react-native-svg": "15.12.1",
		"react-native-url-polyfill": "^3.0.0",
		"react-native-worklets": "0.5.1",
		"react-native-worklets-core": "^1.6.3",
		"zod": "^4.3.6",
		"zustand": "^5.0.12"
	},
	"devDependencies": {
		"@eslint/js": "^9.39.4",
		"@testing-library/jest-native": "^5.4.3",
		"@testing-library/react-native": "^13.3.3",
		"@types/color": "^4.2.1",
		"@types/jest": "29.5.14",
		"@types/jest-image-snapshot": "^6.4.1",
		"@types/react": "~19.1.10",
		"@typescript-eslint/eslint-plugin": "^8.57.2",
		"@typescript-eslint/parser": "^8.57.2",
		"color": "^5.0.3",
		"eslint": "^9.39.4",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-formatjs": "^6.4.4",
		"eslint-plugin-i18next": "^6.1.3",
		"eslint-plugin-no-inline-styles": "^1.0.5",
		"eslint-plugin-react": "^7.37.5",
		"eslint-plugin-react-hooks": "^7.0.1",
		"eslint-plugin-react-native": "^5.0.0",
		"husky": "^9.1.7",
		"i18next-parser": "^9.4.0",
		"jest": "~29.7.0",
		"jest-expo": "~54.0.17",
		"jest-image-snapshot": "^6.5.2",
		"lint-staged": "^16.4.0",
		"prettier": "^3.8.1",
		"react-test-renderer": "^19.1.0",
		"stylelint": "^17.7.0",
		"stylelint-config-standard": "^40.0.0",
		"ts-jest": "^29.4.6",
		"typescript": "~5.9.2"
	},
	"private": true,
	"workspaces": [
		"src/design-system",
		"src/ui-shell",
		"examples/*"
	],
	"lint-staged": {
		"*.{ts,tsx}": [
			"prettier --write",
			"eslint"
		],
		"*.{json,md}": [
			"prettier --write"
		]
	}
}

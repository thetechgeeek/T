{
	"cli": {
		"version": ">= 13.0.0",
		"appVersionSource": "remote"
	},
	"build": {
		"development": {
			"developmentClient": true,
			"distribution": "internal",
			"channel": "development",
			"env": {
				"APP_CONFIG_MODE": "dev",
				"EXPO_PUBLIC_APP_ENV": "dev"
			},
			"ios": {
				"simulator": true
			},
			"android": {
				"buildType": "apk"
			}
		},
		"preview": {
			"distribution": "internal",
			"channel": "preview",
			"env": {
				"APP_CONFIG_MODE": "integration",
				"EXPO_PUBLIC_APP_ENV": "integration"
			},
			"android": {
				"buildType": "apk"
			}
		},
		"production": {
			"autoIncrement": true,
			"channel": "production",
			"env": {
				"APP_CONFIG_MODE": "production",
				"EXPO_PUBLIC_APP_ENV": "production"
			}
		}
	},
	"submit": {
		"production": {}
	}
}

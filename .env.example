# Public app runtime. These values are bundled into Expo builds and must be
# publishable, not service-role or admin secrets.
APP_CONFIG_MODE=dev
EXPO_PUBLIC_APP_ENV=dev
EXPO_PUBLIC_SUPABASE_URL=https://your-dev-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-dev-anon-key

# Integration and e2e test runtime. Store real values in .env.test locally and
# in CI secrets; do not commit real credentials.
SUPABASE_TEST_URL=https://your-test-project.supabase.co
SUPABASE_TEST_PROJECT_REF_ALLOWLIST=your-test-project
SUPABASE_TEST_ANON_KEY=your-test-anon-key
SUPABASE_TEST_SERVICE_ROLE_KEY=optional-service-role-key-for-reset-only
INTEGRATION_TEST_EMAIL=test-user@example.com
INTEGRATION_TEST_PASSWORD=replace-with-local-or-ci-secret

# E2E runner options. The runners map SUPABASE_TEST_* to EXPO_PUBLIC_* before
# app startup; the app runtime itself never falls back to SUPABASE_TEST_*.
E2E_EXPO_PORT=8088
DESIGN_SYSTEM_DEEPLINK=easystock://design-system
